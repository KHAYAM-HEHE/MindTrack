PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/mindtrack
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173

# Optional — AI quotes (client dashboard) and goal/task suggestions. Without keys, sensible fallbacks run.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENROUTER_API_KEY=
# Primary model (if it 404s, fallbacks are tried automatically):
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Comma-separated extra slugs if the primary is retired or rate-limited:
# OPENROUTER_MODEL_FALLBACKS=
# Optional: use a different model for dashboard quotes only
# OPENROUTER_QUOTE_MODEL=
# OPENROUTER_SITE_URL=http://localhost:5000
# OPENROUTER_APP_NAME=MindTrack
